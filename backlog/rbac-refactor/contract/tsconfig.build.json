{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "outDir": "./_dist",
    "lib": ["ES2022"],
    "types": ["node"],
    "rewriteRelativeImportExtensions": true
  },
  "include": [
    "contract-01-atomic-permissions.ts",
    "contract-02-templates.ts",
    "_count-templates.mts"
  ]
}
