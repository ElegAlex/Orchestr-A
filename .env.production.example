# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║                    ORCHESTR'A - Production Configuration                     ║
# ║                                                                              ║
# ║  RECOMMENDED: Run ./scripts/init-env.sh to auto-generate this file          ║
# ║               with secure random secrets.                                    ║
# ║                                                                              ║
# ║  MANUAL: Copy this file to .env.production and fill in the values.          ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

# ┌──────────────────────────────────────────────────────────────────────────────┐
# │ SECRETS [REQUIRED]                                                           │
# │ Generate with: openssl rand -base64 32 | tr -dc 'a-zA-Z0-9' | head -c 32    │
# └──────────────────────────────────────────────────────────────────────────────┘

# PostgreSQL password — the DDL/OWNER role (DATABASE_USER). Used for migrations +
# audit hash-chain maintenance (DATABASE_MIGRATION_URL). Min 16 chars recommended.
DATABASE_PASSWORD=

# TOOL-DEPLOY-001 — restricted RUNTIME role (app_user) password. The API connects
# as this role (DATABASE_URL): full CRUD everywhere but only INSERT+SELECT on
# audit_logs (UPDATE/DELETE/TRUNCATE revoked). Provision the role ONCE per
# environment with packages/database/prisma/init-roles.sql (see prisma/README.md).
APP_DATABASE_PASSWORD=

# Redis password (min 16 chars recommended)
REDIS_PASSWORD=

# JWT signing secret (min 32 chars)
# Generate with: openssl rand -base64 64
JWT_SECRET=

# ┌──────────────────────────────────────────────────────────────────────────────┐
# │ DOMAIN [REQUIRED]                                                            │
# └──────────────────────────────────────────────────────────────────────────────┘

# Your production domain URL(s) for CORS (comma-separated if multiple).
# SEC-012: This variable is REQUIRED in production — the API refuses to start without it.
# Examples: https://orchestr-a.example.com
#           https://app.company.fr, https://admin.company.fr
CORS_ORIGIN=

# API URL as seen from browser (/api if behind nginx reverse proxy)
NEXT_PUBLIC_API_URL=/api

# ┌──────────────────────────────────────────────────────────────────────────────┐
# │ DATABASE [Optional - defaults recommended]                                   │
# └──────────────────────────────────────────────────────────────────────────────┘

DATABASE_NAME=orchestr_a_prod
DATABASE_USER=orchestr_a

# TOOL-DEPLOY-001 — restricted runtime role name (matches init-roles.sql).
APP_DATABASE_USER=app_user

# ┌──────────────────────────────────────────────────────────────────────────────┐
# │ AUTHENTICATION [Optional]                                                    │
# └──────────────────────────────────────────────────────────────────────────────┘

# JWT token validity (formats: 1h, 8h, 1d, 7d, 30d)
JWT_EXPIRES_IN=7d

# ┌──────────────────────────────────────────────────────────────────────────────┐
# │ SECURITY [Optional]                                                          │
# └──────────────────────────────────────────────────────────────────────────────┘

# Rate limiting
THROTTLE_LIMIT=100
THROTTLE_TTL=60

# Swagger API docs (disable in production)
SWAGGER_ENABLED=false

# RBAC guard mode — MUST be 'enforce' in production. Setting 'permissive'
# in production is refused at boot (see apps/api/src/main.ts).
# Leave unset to use the secure default ('enforce').
RBAC_GUARD_MODE=enforce

# SEC-018: NEVER set to 'true' in production — the API will refuse to start.
# The flag returns the raw reset token in the HTTP response (dev/E2E only).
AUTH_EXPOSE_RESET_TOKEN=false

# ┌──────────────────────────────────────────────────────────────────────────────┐
# │ NETWORK [Optional - change only if port conflicts]                           │
# └──────────────────────────────────────────────────────────────────────────────┘

HTTP_PORT=80
HTTPS_PORT=443

# ┌──────────────────────────────────────────────────────────────────────────────┐
# │ EMAIL [Optional - uncomment to enable]                                       │
# └──────────────────────────────────────────────────────────────────────────────┘

# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=noreply@example.com
# SMTP_PASSWORD=
# SMTP_FROM=ORCHESTR'A <noreply@example.com>

# ┌──────────────────────────────────────────────────────────────────────────────┐
# │ MONITORING [Optional - uncomment to enable]                                  │
# └──────────────────────────────────────────────────────────────────────────────┘

# SENTRY_DSN=https://xxx@sentry.io/xxx
# SENTRY_ENVIRONMENT=production

# SA-SEC-012: REQUIRED in production — protects GET /api/metrics (Prometheus scraping).
# Without this, the metrics endpoint is fully open to any caller.
# Generate with: openssl rand -hex 32
METRICS_TOKEN=
