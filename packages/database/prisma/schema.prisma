// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // TOOL-DEPLOY-001 — two-role DB split (defence-in-depth for audit_logs).
  // `url` is the RUNTIME connection: the restricted app role (INSERT+SELECT on
  // audit_logs, full CRUD elsewhere — UPDATE/DELETE/TRUNCATE on audit_logs are
  // REVOKEd, so a trigger bypass is still blocked at the privilege layer).
  // `directUrl` is the DDL connection used by `prisma migrate deploy`, `db push`,
  // `db pull` and the audit hash-chain maintenance scripts: a role that OWNS the
  // schema (full privileges). See prisma/README.md + prisma/init-roles.sql.
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_MIGRATION_URL")
}

// ===========================
// USERS & AUTHENTICATION
// ===========================

model User {
  id                  String   @id @default(uuid())
  // DAT-015: VarChar(254) caps email per RFC 5321; @unique kept for Prisma
  // findUnique compatibility. A LOWER() functional unique index is added via
  // raw SQL in the migration (Prisma PSL cannot express functional indexes).
  email               String   @unique @db.VarChar(254)
  login               String   @unique
  passwordHash        String
  firstName           String
  lastName            String
  // RBAC V4 : FK vers Role (table `roles`). Nullable pendant la transition ;
  // passera NOT NULL après backfill stable. Cf. contract-03 §9.
  roleId              String?
  role                Role?    @relation(name: "UserRoleEntity", fields: [roleId], references: [id])
  departmentId        String?
  isActive            Boolean  @default(true)
  avatarUrl           String?
  avatarPreset        String?
  forcePasswordChange Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  // Relations
  department                       Department?                   @relation("DepartmentUsers", fields: [departmentId], references: [id], onDelete: SetNull)
  userServices                     UserService[]
  managedDepartments               Department[]                  @relation("DepartmentManager")
  managedServices                  Service[]                     @relation("ServiceManager")
  projectMembers                   ProjectMember[]
  createdProjects                  Project[]                     @relation("ProjectCreator")
  tasks                            Task[] // Tâches où l'user est assigné principal
  taskAssignments                  TaskAssignee[] // Tâches où l'user est co-assigné
  leaves                           Leave[]                       @relation("UserLeaves")
  leavesToValidate                 Leave[]                       @relation("LeaveValidator")
  leavesValidated                  Leave[]                       @relation("LeaveValidatedBy")
  delegationsGiven                 LeaveValidationDelegate[]     @relation("DelegatorUser")
  delegationsReceived              LeaveValidationDelegate[]     @relation("DelegateUser")
  leaveBalances                    LeaveBalance[]
  telework                         TeleworkSchedule[]
  teleworkRecurringRules           TeleworkRecurringRule[]       @relation("TeleworkRecurringRuleUser")
  createdTeleworkRules             TeleworkRecurringRule[]       @relation("TeleworkRecurringRuleCreator")
  skills                           UserSkill[]
  timeEntries                      TimeEntry[]                   @relation("TimeEntryUser")
  declaredTimeEntries              TimeEntry[]                   @relation("TimeEntryDeclaredBy")
  createdThirdParties              ThirdParty[]                  @relation("ThirdPartyCreatedBy")
  taskThirdPartyAssignmentsMade    TaskThirdPartyAssignee[]      @relation("TaskThirdPartyAssignedBy")
  projectThirdPartyMembershipsMade ProjectThirdPartyMember[]     @relation("ProjectThirdPartyAssignedBy")
  comments                         Comment[]
  personalTodos                    PersonalTodo[]
  createdHolidays                  Holiday[]                     @relation("HolidayCreator")
  createdSchoolVacations           SchoolVacation[]              @relation("SchoolVacationCreator")
  createdEvents                    Event[]                       @relation("EventCreator")
  eventParticipations              EventParticipant[]
  createdPredefinedTasks           PredefinedTask[]              @relation("PredefinedTaskCreator")
  predefinedTaskAssignments        PredefinedTaskAssignment[]    @relation("PredefinedTaskAssignmentUser")
  assignedPredefinedTasks          PredefinedTaskAssignment[]    @relation("PredefinedTaskAssignmentAssigner")
  predefinedTaskRecurringRules     PredefinedTaskRecurringRule[] @relation("PredefinedTaskRecurringRuleUser")
  createdPredefinedTaskRules       PredefinedTaskRecurringRule[] @relation("PredefinedTaskRecurringRuleCreator")
  passwordResetTokens              PasswordResetToken[]          @relation("PasswordResetTokenUser")
  createdPasswordResetTokens       PasswordResetToken[]          @relation("PasswordResetTokenCreator")
  refreshTokens                    RefreshToken[]
  managedProjects                  Project[]                     @relation("ProjectManager")
  sponsoredProjects                Project[]                     @relation("ProjectSponsor")
  archivedProjects                 Project[]                     @relation("ProjectArchiver")
  auditLogs                        AuditLog[]                    @relation("AuditActor")
  completedAssignments             PredefinedTaskAssignment[]    @relation("AssignmentCompletedBy")

  @@index([isActive])     // PER-011: hot predicate — presence, analytics, workload, leaves import
  @@index([departmentId]) // PER-011: hot predicate — organigramme, per-department queries
  @@index([roleId])       // PER-011: hot predicate — RBAC V4 role-scoped queries
  @@map("users")
}

// ===========================
// ORGANIZATION
// ===========================

model Department {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  managerId   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  manager  User?     @relation("DepartmentManager", fields: [managerId], references: [id], onDelete: SetNull)
  users    User[]    @relation("DepartmentUsers")
  services Service[]

  @@index([managerId]) // DAT-011: FK without auto-index
  @@map("departments")
}

model Service {
  id           String   @id @default(uuid())
  name         String
  description  String?
  color        String?
  departmentId String
  managerId    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  department   Department    @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  manager      User?         @relation("ServiceManager", fields: [managerId], references: [id], onDelete: SetNull)
  userServices UserService[]

  // DAT-016 — name unique PER department, NOT globally: two services with the
  // same name in different departments remain legal (the app layer already
  // pre-checks { name, departmentId }).
  @@unique([departmentId, name])
  @@index([managerId]) // DAT-011: FK without auto-index (departmentId already leading in unique composite)
  @@map("services")
}

model UserService {
  id        String   @id @default(uuid())
  userId    String
  serviceId String
  createdAt DateTime @default(now())

  // Relations
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([userId, serviceId])
  @@map("user_services")
}

// ===========================
// PROJECTS
// ===========================

model Project {
  id              String        @id @default(uuid())
  name            String
  description     String?
  status          ProjectStatus @default(DRAFT)
  priority        Priority      @default(NORMAL)
  startDate       DateTime?
  endDate         DateTime?
  budgetHours     Int?
  icon            String?
  hiddenStatuses  TaskStatus[]  @default([])
  visibleStatuses String[]      @default([])
  createdById     String?
  managerId       String?
  sponsorId       String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  archivedAt      DateTime?
  archivedById    String?

  // Relations
  createdBy         User?                     @relation("ProjectCreator", fields: [createdById], references: [id], onDelete: SetNull)
  manager           User?                     @relation("ProjectManager", fields: [managerId], references: [id], onDelete: SetNull)
  sponsor           User?                     @relation("ProjectSponsor", fields: [sponsorId], references: [id], onDelete: SetNull)
  archivedBy        User?                     @relation("ProjectArchiver", fields: [archivedById], references: [id], onDelete: SetNull)
  members           ProjectMember[]
  thirdPartyMembers ProjectThirdPartyMember[]
  clients           ProjectClient[]
  epics             Epic[]
  milestones        Milestone[]
  tasks             Task[]
  documents         Document[]
  timeEntries       TimeEntry[]
  events            Event[]
  snapshots         ProjectSnapshot[]

  @@index([archivedAt])
  @@index([createdById]) // DAT-011: FK without auto-index
  @@index([managerId])   // DAT-011: FK without auto-index
  @@index([sponsorId])   // DAT-011: FK without auto-index
  @@index([archivedById]) // DAT-011: FK without auto-index
  @@map("projects")
}

model ProjectSnapshot {
  id                 String   @id @default(uuid())
  projectId          String
  progress           Decimal  @db.Decimal(5, 2) // 0.00 – 100.00 ; DAT-005 (Decimal exact arithmetic, no IEEE 754 drift)
  tasksDone          Int
  tasksTotal         Int
  tasksInProgress    Int      @default(0)
  tasksBlocked       Int      @default(0)
  milestonesReached  Int      @default(0)
  milestonesOverdue  Int      @default(0)
  milestonesUpcoming Int      @default(0)
  date               DateTime @default(now())
  createdAt          DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Restrict) // DAT-007: Restrict (was Cascade) — progress history must not be erased by a Project hard-delete

  @@unique([projectId, date]) // COR-014: DB-level race guard; date stored as startOfDay (midnight UTC)
  @@index([date])
  @@map("project_snapshots")
}

enum ProjectStatus {
  DRAFT
  ACTIVE
  SUSPENDED
  COMPLETED
  CANCELLED
}

model ProjectMember {
  id         String    @id @default(uuid())
  projectId  String
  userId     String
  role       String // Chef de projet, Membre, Observateur...
  allocation Int? // Pourcentage d'allocation (0-100)
  startDate  DateTime?
  endDate    DateTime?
  createdAt  DateTime  @default(now())

  // Relations
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@map("project_members")
}

// ===========================
// EPICS & MILESTONES
// ===========================

model Epic {
  id          String    @id @default(uuid())
  name        String
  description String?
  projectId   String
  progress    Int       @default(0) // 0-100%
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks   Task[]

  @@index([projectId]) // DAT-011: FK without auto-index
  @@map("epics")
}

model Milestone {
  id          String          @id @default(uuid())
  name        String
  description String?
  projectId   String
  dueDate     DateTime
  status      MilestoneStatus @default(PENDING)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  // Relations
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks   Task[]

  @@index([projectId]) // DAT-011: FK without auto-index
  @@map("milestones")
}

enum MilestoneStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  DELAYED
}

// ===========================
// TASKS
// ===========================

model Task {
  id                     String     @id @default(uuid())
  title                  String
  description            String?
  status                 TaskStatus @default(TODO)
  priority               Priority   @default(NORMAL)
  projectId              String? // Nullable pour permettre les tâches orphelines (réunions, tâches transverses)
  epicId                 String?
  milestoneId            String?
  assigneeId             String? // Assigné principal (rétrocompatibilité)
  estimatedHours         Decimal?   @db.Decimal(5, 2) // hours ; DAT-005
  progress               Int        @default(0) // 0-100%
  startDate              DateTime?
  endDate                DateTime?
  startTime              String? // Horaire de début optionnel (format HH:MM)
  endTime                String? // Horaire de fin optionnel (format HH:MM)
  isExternalIntervention Boolean    @default(false)
  createdAt              DateTime   @default(now())
  updatedAt              DateTime   @updatedAt

  // Relations
  project             Project?                 @relation(fields: [projectId], references: [id], onDelete: Restrict) // DAT-007: Restrict (was Cascade) — a Project with tasks cannot be hard-deleted; archive it instead
  epic                Epic?                    @relation(fields: [epicId], references: [id], onDelete: SetNull)
  milestone           Milestone?               @relation(fields: [milestoneId], references: [id], onDelete: SetNull)
  assignee            User?                    @relation(fields: [assigneeId], references: [id], onDelete: SetNull)
  assignees           TaskAssignee[] // Relation many-to-many pour multiple assignés
  thirdPartyAssignees TaskThirdPartyAssignee[]
  dependencies        TaskDependency[]         @relation("TaskDependencies")
  dependents          TaskDependency[]         @relation("DependentTasks")
  timeEntries         TimeEntry[]
  comments            Comment[]
  raci                TaskRACI[]
  subtasks            Subtask[]

  @@index([projectId])
  @@index([assigneeId])
  @@index([status])
  @@index([endDate])
  @@index([startDate])
  @@index([milestoneId])
  @@index([epicId])
  @@index([projectId, status])
  @@map("tasks")
}

// Table de liaison pour assignation multiple de tâches
model TaskAssignee {
  id        String   @id @default(uuid())
  taskId    String
  userId    String
  createdAt DateTime @default(now())

  // Relations
  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([taskId, userId])
  @@index([taskId])
  @@index([userId])
  @@map("task_assignees")
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
  BLOCKED
}

enum Priority {
  LOW
  NORMAL
  HIGH
  CRITICAL
}

model TaskDependency {
  id              String   @id @default(uuid())
  taskId          String
  dependsOnTaskId String
  createdAt       DateTime @default(now())

  // Relations
  task          Task @relation("TaskDependencies", fields: [taskId], references: [id], onDelete: Cascade)
  dependsOnTask Task @relation("DependentTasks", fields: [dependsOnTaskId], references: [id], onDelete: Cascade)

  @@unique([taskId, dependsOnTaskId])
  @@map("task_dependencies")
}

model TaskRACI {
  id        String   @id @default(uuid())
  taskId    String
  userId    String
  role      RACIRole
  createdAt DateTime @default(now())

  // Relations
  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([taskId, userId, role])
  @@map("task_raci")
}

enum RACIRole {
  RESPONSIBLE // Réalisateur
  ACCOUNTABLE // Approbateur
  CONSULTED // Consulté
  INFORMED // Informé
}

model Subtask {
  id          String   @id @default(uuid())
  title       String
  description String?
  isCompleted Boolean  @default(false)
  position    Int      @default(0)
  taskId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@map("subtasks")
}

// ===========================
// TIME TRACKING
// ===========================

model TimeEntry {
  id           String       @id @default(uuid())
  userId       String?
  thirdPartyId String?
  declaredById String
  projectId    String?
  taskId       String?
  date         DateTime     @db.Date
  hours        Decimal      @db.Decimal(5, 2) // hours, max 999.99 ; DAT-005
  description  String?
  isDismissal  Boolean      @default(false)
  activityType ActivityType
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  // Relations
  user       User?       @relation("TimeEntryUser", fields: [userId], references: [id], onDelete: Cascade)
  thirdParty ThirdParty? @relation(fields: [thirdPartyId], references: [id], onDelete: Cascade)
  declaredBy User        @relation("TimeEntryDeclaredBy", fields: [declaredById], references: [id], onDelete: Restrict)
  project    Project?    @relation(fields: [projectId], references: [id], onDelete: Restrict) // DAT-007: Restrict (was SetNull) — logged time must not silently lose its Project link on hard-delete
  task       Task?       @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([userId, date])
  @@index([thirdPartyId, date])
  @@index([declaredById])
  @@index([projectId, date])
  @@index([taskId])
  @@index([taskId, userId])
  @@map("time_entries")
}

enum ActivityType {
  DEVELOPMENT
  MEETING
  SUPPORT
  TRAINING
  OTHER
}

// ===========================
// THIRD PARTIES
// ===========================

enum ThirdPartyType {
  EXTERNAL_PROVIDER
  INTERNAL_NON_USER
  LEGAL_ENTITY
}

model ThirdParty {
  id               String         @id @default(uuid())
  type             ThirdPartyType
  organizationName String
  contactFirstName String?
  contactLastName  String?
  contactEmail     String?
  notes            String?
  isActive         Boolean        @default(true)
  createdById      String
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  createdBy          User                      @relation("ThirdPartyCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  taskAssignments    TaskThirdPartyAssignee[]
  projectMemberships ProjectThirdPartyMember[]
  timeEntries        TimeEntry[]

  @@index([type, isActive])
  @@index([organizationName])
  @@map("third_parties")
}

model TaskThirdPartyAssignee {
  id           String   @id @default(uuid())
  taskId       String
  thirdPartyId String
  assignedById String
  createdAt    DateTime @default(now())

  task       Task       @relation(fields: [taskId], references: [id], onDelete: Cascade)
  thirdParty ThirdParty @relation(fields: [thirdPartyId], references: [id], onDelete: Cascade)
  assignedBy User       @relation("TaskThirdPartyAssignedBy", fields: [assignedById], references: [id], onDelete: Restrict)

  @@unique([taskId, thirdPartyId])
  @@index([taskId])
  @@index([thirdPartyId])
  @@map("task_third_party_assignees")
}

model ProjectThirdPartyMember {
  id           String   @id @default(uuid())
  projectId    String
  thirdPartyId String
  allocation   Int?
  assignedById String
  createdAt    DateTime @default(now())

  project    Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  thirdParty ThirdParty @relation(fields: [thirdPartyId], references: [id], onDelete: Cascade)
  assignedBy User       @relation("ProjectThirdPartyAssignedBy", fields: [assignedById], references: [id], onDelete: Restrict)

  @@unique([projectId, thirdPartyId])
  @@index([projectId])
  @@index([thirdPartyId])
  @@map("project_third_party_members")
}

// ===========================
// CLIENTS
// ===========================

model Client {
  id        String   @id @default(uuid())
  name      String   @unique // DAT-036: globally unique, defense-in-depth on top of the service-layer pre-check
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projects ProjectClient[]

  @@index([isActive])
  @@map("clients")
}

model ProjectClient {
  projectId String
  clientId  String
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  client  Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@id([projectId, clientId])
  @@index([projectId])
  @@index([clientId])
  @@map("project_clients")
}

// ===========================
// HR - LEAVES
// ===========================

// Configuration des types de congés (modifiable par admin/responsable)
model LeaveTypeConfig {
  id               String   @id @default(uuid())
  code             String   @unique // Code technique (ex: CP, RTT, SICK_LEAVE)
  name             String // Nom affiché (ex: "Congés payés")
  description      String? // Description optionnelle
  color            String   @default("#10B981") // Couleur pour l'affichage
  icon             String   @default("🌴") // Emoji/icône
  isPaid           Boolean  @default(true) // Congé rémunéré ou non
  requiresApproval Boolean  @default(true) // Nécessite validation
  isActive         Boolean  @default(true) // Type actif ou archivé
  isSystem         Boolean  @default(false) // Type système (non supprimable)
  sortOrder        Int      @default(0) // Ordre d'affichage
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relations
  leaves        Leave[]
  leaveBalances LeaveBalance[]

  @@map("leave_type_configs")
}

model Leave {
  id          String      @id @default(uuid())
  userId      String
  leaveTypeId String      @map("leave_type_id") // Référence au type de congé
  type        LeaveType? // Gardé pour rétrocompatibilité (sera supprimé plus tard)
  startDate   DateTime    @db.Date
  endDate     DateTime    @db.Date
  halfDay     HalfDay?
  days        Decimal     @db.Decimal(6, 2) // Jours ouvrés calculés ; DAT-005 (max 9999.99)
  status      LeaveStatus @default(PENDING)
  comment     String?

  // Champs de validation
  validatorId       String?   @map("validator_id") // Qui doit valider (manager, responsable ou délégué)
  validatedById     String?   @map("validated_by_id") // Qui a effectivement validé/rejeté
  validatedAt       DateTime? @map("validated_at") // Date de validation/rejet
  validationComment String?   @map("validation_comment") // Commentaire du validateur (motif de refus, etc.)
  selfApproved      Boolean   @default(false) // True si le validateur est le demandeur (leaves:self_approve), permet à l'audit de distinguer auto-validation et validation hiérarchique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user        User            @relation("UserLeaves", fields: [userId], references: [id], onDelete: Cascade)
  leaveType   LeaveTypeConfig @relation(fields: [leaveTypeId], references: [id])
  validator   User?           @relation("LeaveValidator", fields: [validatorId], references: [id], onDelete: SetNull)
  validatedBy User?           @relation("LeaveValidatedBy", fields: [validatedById], references: [id], onDelete: SetNull)

  @@index([userId, status])
  @@index([validatorId, status])
  @@index([startDate, endDate])
  @@index([leaveTypeId, status])
  @@index([validatedById]) // DAT-011: FK without auto-index (not covered by DAT-010 composites)
  @@index([userId, startDate]) // PER-010: user leave history by date range
  @@index([status, startDate]) // PER-010: status-scoped calendar queries
  @@index([userId, leaveTypeId, startDate]) // PER-010: per-user per-type date range
  @@map("leaves")
}

// Table de délégation de validation des congés
model LeaveValidationDelegate {
  id          String   @id @default(uuid())
  delegatorId String   @map("delegator_id") // Qui délègue (manager/responsable)
  delegateId  String   @map("delegate_id") // À qui on délègue
  startDate   DateTime @map("start_date") @db.Date
  endDate     DateTime @map("end_date") @db.Date
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  delegator User @relation("DelegatorUser", fields: [delegatorId], references: [id], onDelete: Cascade)
  delegate  User @relation("DelegateUser", fields: [delegateId], references: [id], onDelete: Cascade)

  @@index([delegatorId]) // DAT-011: FK without auto-index
  @@index([delegateId])  // DAT-011: FK without auto-index
  @@map("leave_validation_delegates")
}

// Enum gardé pour rétrocompatibilité (sera supprimé après migration complète)
enum LeaveType {
  CP // Congés payés
  RTT
  SICK_LEAVE // Maladie
  UNPAID // Sans solde
  OTHER
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLATION_REQUESTED
}

enum HalfDay {
  MORNING
  AFTERNOON
}

// Soldes de congés par utilisateur, type et année
// Si userId est null → valeur globale par défaut pour ce type et cette année.
// Note : un index unique partiel `leave_balances_global_unique` (défini en
// SQL brut dans la migration 20260523171000) empêche les doublons sur la
// tranche userId IS NULL — Prisma ne sait pas exprimer un UNIQUE WHERE
// dans @@unique, donc cet index n'apparaît pas dans ce schema mais sa
// présence est garantie au niveau base par la migration.
model LeaveBalance {
  id          String   @id @default(uuid())
  userId      String? // null = solde global par défaut
  leaveTypeId String
  year        Int // Année d'application
  totalDays   Decimal  @db.Decimal(6, 2) // Nombre de jours attribués ; DAT-005 (max 9999.99)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  user      User?           @relation(fields: [userId], references: [id], onDelete: Cascade)
  leaveType LeaveTypeConfig @relation(fields: [leaveTypeId], references: [id], onDelete: Cascade)

  @@unique([userId, leaveTypeId, year])
  @@index([year])
  @@index([leaveTypeId])
  @@map("leave_balances")
}

// ===========================
// HR - TELEWORK
// ===========================

model TeleworkSchedule {
  id          String   @id @default(uuid())
  userId      String
  date        DateTime @db.Date
  isTelework  Boolean
  isException Boolean  @default(false) // Exception au planning récurrent
  createdAt   DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@map("telework_schedules")
}

// ===========================
// HR - SKILLS
// ===========================

model Skill {
  id            String        @id @default(uuid())
  name          String        @unique
  category      SkillCategory
  description   String?
  requiredCount Int           @default(1) // Nombre de ressources necessaires pour couvrir cette competence
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  // Relations
  users UserSkill[]

  @@map("skills")
}

enum SkillCategory {
  TECHNICAL
  METHODOLOGY
  SOFT_SKILL
  BUSINESS
}

model UserSkill {
  userId      String
  skillId     String
  level       SkillLevel
  validatedBy String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  // Relations
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  skill Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([userId, skillId])
  @@map("user_skills")
}

enum SkillLevel {
  BEGINNER // Débutant
  INTERMEDIATE // Intermédiaire
  EXPERT // Expert
  MASTER // Maître
}

// ===========================
// DOCUMENTS
// ===========================

model Document {
  id          String   @id @default(uuid())
  name        String
  description String?
  url         String
  mimeType    String
  size        Int // Size in bytes
  projectId   String
  uploadedBy  String
  createdAt   DateTime @default(now())

  // Relations
  project Project @relation(fields: [projectId], references: [id], onDelete: Restrict) // DAT-007: Restrict (was Cascade) — project documents must not be erased by a Project hard-delete

  @@index([projectId])  // DAT-011: FK without auto-index
  @@index([uploadedBy]) // DAT-011: FK without auto-index
  @@map("documents")
}

// ===========================
// COMMENTS
// ===========================

model Comment {
  id        String   @id @default(uuid())
  content   String
  taskId    String
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  task   Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([taskId])   // DAT-011: FK without auto-index
  @@index([authorId]) // DAT-011: FK without auto-index
  @@map("comments")
}

// ===========================
// PERSONAL TODO LIST
// ===========================

model PersonalTodo {
  id          String    @id @default(uuid())
  userId      String
  text        String
  completed   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  completedAt DateTime?
  updatedAt   DateTime  @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, completed, createdAt])
  @@map("personal_todos")
}

// ===========================
// APPLICATION SETTINGS
// ===========================

// DAT-012 — enum promotion. Values stay lowercase to match existing data (no
// data migration). The set is developer-extended via SettingsService.DEFAULT_SETTINGS;
// adding a category here is the deliberate compile-time coupling that prevents drift.
enum AppSettingsCategory {
  display
  general
  planning
}

model AppSettings {
  id          String   @id @default(uuid())
  key         String   @unique
  value       String // JSON stringified value
  category    AppSettingsCategory @default(general) // DAT-012: was String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("app_settings")
}

// ===========================
// HOLIDAYS (JOURS FÉRIÉS)
// ===========================

model Holiday {
  id          String      @id @default(uuid())
  date        DateTime    @db.Date
  name        String      @db.VarChar(100)
  type        HolidayType @default(LEGAL)
  isWorkDay   Boolean     @default(false) // true = jour ouvré, false = non ouvré (chômé)
  description String?     @db.VarChar(255)
  recurring   Boolean     @default(false) // Se répète chaque année à la même date
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  createdById String

  // Relations
  createdBy User @relation("HolidayCreator", fields: [createdById], references: [id])

  @@unique([date])
  @@index([date])
  @@index([createdById]) // DAT-011: FK without auto-index
  @@map("holidays")
}

enum HolidayType {
  LEGAL // Jour férié légal (1er janvier, 14 juillet, etc.)
  BRIDGE // Pont accordé
  CLOSURE // Fermeture exceptionnelle
  CUSTOM // Autre (personnalisé)
}

enum SchoolVacationZone {
  A
  B
  C
}

enum SchoolVacationSource {
  IMPORT
  MANUAL
}

// ===========================
// SCHOOL VACATIONS (VACANCES SCOLAIRES)
// ===========================

model SchoolVacation {
  id          String               @id @default(uuid())
  name        String               @db.VarChar(100)
  startDate   DateTime             @db.Date
  endDate     DateTime             @db.Date
  zone        SchoolVacationZone
  year        Int
  source      SchoolVacationSource @default(MANUAL)
  createdById String
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  // Relations
  createdBy User @relation("SchoolVacationCreator", fields: [createdById], references: [id])

  @@unique([name, zone, year])
  @@index([startDate, endDate])
  @@index([zone, year])
  @@map("school_vacations")
}

// ===========================
// EVENTS (ÉVÉNEMENTS)
// ===========================

model Event {
  id                     String   @id @default(uuid())
  title                  String
  description            String?
  date                   DateTime
  startTime              String? // Format HH:MM
  endTime                String? // Format HH:MM
  isAllDay               Boolean  @default(true)
  isExternalIntervention Boolean  @default(false)
  projectId              String?
  createdById            String
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  // Recurrence fields
  isRecurring            Boolean   @default(false)
  recurrenceWeekInterval Int?
  recurrenceDay          Int? // 0=Monday, 1=Tuesday, ..., 6=Sunday
  recurrenceEndDate      DateTime?
  parentEventId          String?

  // Relations
  project      Project?           @relation(fields: [projectId], references: [id], onDelete: SetNull)
  createdBy    User               @relation("EventCreator", fields: [createdById], references: [id], onDelete: Cascade)
  participants EventParticipant[]
  parentEvent  Event?             @relation("EventRecurrence", fields: [parentEventId], references: [id], onDelete: Cascade)
  childEvents  Event[]            @relation("EventRecurrence")

  @@index([projectId])    // DAT-011: FK without auto-index
  @@index([createdById])  // DAT-011: FK without auto-index
  @@index([parentEventId]) // DAT-011: FK without auto-index (recurrence chain lookups)
  @@index([date])                // PER-012: primary range filter — /planning 6-month window
  @@index([createdById, date])   // PER-012: owner + date composite — list events by creator with range
  @@map("events")
}

model EventParticipant {
  eventId String
  userId  String

  // Relations
  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([eventId, userId])
  @@index([userId]) // PER-012: participant look-up without full table scan
  @@map("event_participants")
}

// ===========================
// HR - TELEWORK RECURRING RULES
// ===========================

model TeleworkRecurringRule {
  id          String    @id @default(uuid())
  userId      String
  dayOfWeek   Int // 0=Monday, 1=Tuesday, ..., 6=Sunday
  startDate   DateTime
  endDate     DateTime?
  isActive    Boolean   @default(true)
  createdById String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  user      User @relation("TeleworkRecurringRuleUser", fields: [userId], references: [id], onDelete: Cascade)
  createdBy User @relation("TeleworkRecurringRuleCreator", fields: [createdById], references: [id], onDelete: Cascade)

  @@unique([userId, dayOfWeek, startDate])
  @@map("telework_recurring_rules")
}

// ===========================
// PREDEFINED TASKS
// ===========================

// DAT-012 — enum promotion of closed free-string value sets.
enum PredefinedTaskDuration {
  HALF_DAY
  FULL_DAY
  TIME_SLOT
}

// Shared by PredefinedTaskAssignment.period and PredefinedTaskRecurringRule.period
// (identical value set). Distinct from HalfDay (leaves) which has no FULL_DAY.
enum DayPeriod {
  MORNING
  AFTERNOON
  FULL_DAY
}

enum AssignmentCompletionStatus {
  NOT_DONE
  IN_PROGRESS
  DONE
  NOT_APPLICABLE
}

enum RecurrenceType {
  WEEKLY
  MONTHLY_ORDINAL
  MONTHLY_DAY
}

model PredefinedTask {
  id                     String   @id @default(uuid())
  name                   String
  description            String?
  color                  String?
  icon                   String?
  defaultDuration        PredefinedTaskDuration // DAT-012: was String "HALF_DAY"|"FULL_DAY"|"TIME_SLOT"
  startTime              String? // Format "HH:mm", utilisé quand defaultDuration = "TIME_SLOT"
  endTime                String? // Format "HH:mm", utilisé quand defaultDuration = "TIME_SLOT"
  isExternalIntervention Boolean  @default(false)
  isTeleworkAllowed      Boolean  @default(true)
  isActive               Boolean  @default(true)
  weight                 Int      @default(1) // 1..5, pondération pour équilibrage
  createdById            String
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  // Relations
  createdBy      User                          @relation("PredefinedTaskCreator", fields: [createdById], references: [id], onDelete: Cascade)
  assignments    PredefinedTaskAssignment[]
  recurringRules PredefinedTaskRecurringRule[]

  @@index([createdById]) // DAT-011: FK without auto-index
  @@map("predefined_tasks")
}

model PredefinedTaskAssignment {
  id                  String    @id @default(uuid())
  predefinedTaskId    String
  userId              String
  date                DateTime
  period              DayPeriod // DAT-012: was String "MORNING"|"AFTERNOON"|"FULL_DAY"
  assignedById        String
  isRecurring         Boolean   @default(false)
  recurringRuleId     String?
  completionStatus    AssignmentCompletionStatus @default(NOT_DONE) // DAT-012: was String
  completedAt         DateTime?
  completedById       String?
  notApplicableReason String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  // Relations
  predefinedTask PredefinedTask               @relation(fields: [predefinedTaskId], references: [id], onDelete: Cascade)
  user           User                         @relation("PredefinedTaskAssignmentUser", fields: [userId], references: [id], onDelete: Cascade)
  assignedBy     User                         @relation("PredefinedTaskAssignmentAssigner", fields: [assignedById], references: [id], onDelete: Cascade)
  recurringRule  PredefinedTaskRecurringRule? @relation(fields: [recurringRuleId], references: [id], onDelete: SetNull)
  completedBy    User?                        @relation("AssignmentCompletedBy", fields: [completedById], references: [id], onDelete: SetNull)

  @@unique([predefinedTaskId, userId, date, period])
  @@index([date, userId])
  @@index([completionStatus, date])
  @@map("predefined_task_assignments")
}

model PredefinedTaskRecurringRule {
  id                String    @id @default(uuid())
  predefinedTaskId  String
  userId            String
  dayOfWeek         Int? // 0=Monday..6=Sunday ; NULL pour MONTHLY_DAY
  period            DayPeriod // DAT-012: was String "MORNING"|"AFTERNOON"|"FULL_DAY"
  weekInterval      Int       @default(1) // 1=weekly, 2=biweekly... pour WEEKLY uniquement
  recurrenceType    RecurrenceType @default(WEEKLY) // DAT-012: was String
  monthlyOrdinal    Int? // 1..5 (5 = dernière occurrence du mois) pour MONTHLY_ORDINAL
  monthlyDayOfMonth Int? // 1..31 pour MONTHLY_DAY
  startDate         DateTime
  endDate           DateTime?
  isActive          Boolean   @default(true)
  createdById       String
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations
  predefinedTask PredefinedTask             @relation(fields: [predefinedTaskId], references: [id], onDelete: Cascade)
  user           User                       @relation("PredefinedTaskRecurringRuleUser", fields: [userId], references: [id], onDelete: Cascade)
  createdBy      User                       @relation("PredefinedTaskRecurringRuleCreator", fields: [createdById], references: [id], onDelete: Cascade)
  assignments    PredefinedTaskAssignment[]

  @@index([predefinedTaskId]) // DAT-011: FK without auto-index
  @@index([userId])           // DAT-011: FK without auto-index
  @@index([createdById])      // DAT-011: FK without auto-index
  @@map("predefined_task_recurring_rules")
}

// ===========================
// PASSWORD RESET TOKENS
// ===========================

model PasswordResetToken {
  id          String    @id @default(uuid())
  userId      String
  token       String    @unique
  expiresAt   DateTime
  usedAt      DateTime?
  createdById String // Admin qui a généré le token
  createdAt   DateTime  @default(now())

  // Relations
  user      User @relation("PasswordResetTokenUser", fields: [userId], references: [id], onDelete: Cascade)
  createdBy User @relation("PasswordResetTokenCreator", fields: [createdById], references: [id], onDelete: Cascade)

  @@index([userId])      // DAT-011: FK without auto-index
  @@index([createdById]) // DAT-011: FK without auto-index
  @@map("password_reset_tokens")
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  userAgent String?
  ip        String?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

// ===========================
// RBAC V4 — Rôles + templates hardcodés (cf. contract-03 §2.1 + §9)
// ===========================

// Chaque rôle pointe sur un template hardcodé (cf. packages/rbac
// ROLE_TEMPLATES) qui détermine entièrement ses permissions. Plusieurs
// rôles peuvent partager un même templateKey.
model Role {
  id String @id @default(uuid())

  /// Identifiant stable, unique. Sert de clé à PermissionsService.
  /// Ex: "ADMIN", "CHEF_DE_PROJET_SENIOR".
  code String @unique

  /// Libellé affiché dans l'UI (éditable par l'admin).
  label String

  /// Rattachement au template hardcodé. NOT NULL — détermine les permissions.
  /// String stocké pour conserver le typage côté code (RoleTemplateKey).
  templateKey String

  description String?

  /// Rôle système non modifiable et non supprimable (cf. D9 po-decisions).
  isSystem Boolean @default(false)

  /// Rôle par défaut pour un nouvel utilisateur.
  isDefault Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users User[] @relation(name: "UserRoleEntity")

  @@index([templateKey])
  @@index([isDefault])
  @@map("roles")
}

/// Journal d'audit persistant pour traçabilité RGPD des actions métier.
/// Append-only ENFORCÉ au niveau DB (OBS-002 / DAT-009) :
///  - trigger BEFORE UPDATE/DELETE -> RAISE EXCEPTION (audit_logs_no_update_delete) ;
///  - chaîne d'intégrité prevHash/rowHash (sha256) calculée à l'INSERT ;
///  - snapshot actorEmail/actorLabel figé à l'INSERT (survit à la suppression de l'acteur).
/// La FK actorId est passée onDelete: NoAction (au lieu de SetNull) : un SET NULL
/// déclencherait un UPDATE bloqué par le trigger d'immutabilité — le snapshot
/// actorEmail/actorLabel préserve l'identité de l'acteur sans muter le journal.
model AuditLog {
  id         String   @id @default(uuid())
  /// Code de l'action (ex. ASSIGNMENT_STATUS_CHANGED).
  action     String
  /// Type de la ressource concernée (ex. PredefinedTaskAssignment, PredefinedTaskRange).
  entityType String
  /// Id de la ressource (ou id composite en string pour une plage).
  entityId   String
  /// Utilisateur à l'origine de l'action, nullable pour actions système (cron, job).
  actorId    String?
  actor      User?    @relation("AuditActor", fields: [actorId], references: [id], onDelete: NoAction)
  /// Email de l'acteur figé au moment du log (RGPD : snapshot, pas de JOIN). NULL si action système.
  actorEmail String?
  /// Libellé lisible de l'acteur (prénom + nom) figé au moment du log. NULL si action système.
  actorLabel String?
  /// Payload contextuel (before/after, raison, plage...). JSONB côté Postgres.
  payload    Json?
  /// DAT-021 — version du schéma Zod du payload (payload-schemas.ts). v1 = forme
  /// implicite courante de tous les codes d'action. Incluse dans le hash de la
  /// ligne (computeRowHash) : une dérive de version se propage au rowHash. Une v2
  /// future coexisterait dans le registre Zod, dispatchée sur cette colonne.
  schemaVersion Int   @default(1)
  /// Hash sha256 (hex) de la ligne précédente — NULL pour la première ligne (genèse).
  prevHash   String?
  /// Hash sha256 (hex) de cette ligne (chaîne d'intégrité, calculé à l'INSERT).
  rowHash    String
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([actorId, createdAt])
  /// DAT-021 — supporte le futur dispatch de lecture v1/v2 par version de schéma.
  @@index([schemaVersion])
  /// DAT-021 — GIN index (jsonb_path_ops) for JSONB containment queries on payload.
  /// Declared in PSL so `prisma migrate dev --create-only` does not see the raw-SQL
  /// index (migration 20260526120000) as drift and emit a spurious DROP.
  @@index([payload(ops: JsonbPathOps)], type: Gin, map: "audit_logs_payload_gin")
  @@map("audit_logs")
}

/// OBS-012 — Deploy / release ledger. One row per running-container boot in a
/// deploy context, written by DeploymentsService at OnApplicationBootstrap. Lets
/// an auditor answer "which release was live at time T" by ordering on deployedAt.
/// No FK to users: deployedBy is a frozen string (operator email / 'ci'), so the
/// record survives user deletion — same RGPD snapshot rationale as audit_logs
/// actorEmail. Infra event, NOT bound by the audit_logs immutability trigger.
model Deployment {
  id                  String   @id @default(uuid())
  /// Git commit SHA of the running release, injected via env RELEASE_SHA at deploy
  /// time (scripts/deploy-prod.sh). 'unknown' if the operator did not pin it.
  releaseSha          String
  /// When this release booted (= the start of its running interval).
  deployedAt          DateTime @default(now())
  /// Who triggered the deploy: operator email or 'ci'. Frozen string, no FK.
  deployedBy          String
  /// Target environment: 'production' / 'staging' / 'development'.
  environment         String
  /// process.version of the running Node runtime.
  nodeVersion         String
  /// Names of the Prisma migrations applied at boot (from _prisma_migrations).
  dbMigrationsApplied Json?

  @@index([deployedAt])
  @@index([environment, deployedAt])
  @@map("deployments")
}
