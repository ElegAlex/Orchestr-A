# ===========================
# DATABASE
# ===========================
DATABASE_URL="postgresql://orchestr_a:orchestr_a_dev_password@localhost:5432/orchestr_a_v2"
POSTGRES_USER=orchestr_a
POSTGRES_PASSWORD=orchestr_a_dev_password
POSTGRES_DB=orchestr_a_v2
POSTGRES_PORT=5432

# ===========================
# REDIS
# ===========================
REDIS_URL="redis://localhost:6379"
REDIS_PORT=6379

# ===========================
# JWT & AUTH
# ===========================
JWT_SECRET=your_super_secret_key_change_in_production_min_32_chars
# Access token TTL (short — rotated via refresh token)
JWT_ACCESS_TTL=15m
# Refresh token TTL
JWT_REFRESH_TTL=7d
# Legacy alias for JWT_ACCESS_TTL — read as fallback if JWT_ACCESS_TTL unset
JWT_EXPIRES_IN=15m

# ===========================
# SEED
# ===========================
SEED_ADMIN_PASSWORD=  # set to seed an admin user; leave empty to auto-generate (non-prod) or skip (prod)

# ===========================
# API
# ===========================
API_PORT=4000
API_PREFIX=/api
# Server-side only — used by API proxy route handler
API_URL=http://localhost:4000
NODE_ENV=development
SWAGGER_ENABLED=false  # NEVER set to true in production without SWAGGER_USER/SWAGGER_PASS
SWAGGER_USER=          # if set with SWAGGER_PASS, protects /api/docs with basic auth
SWAGGER_PASS=
ALLOWED_ORIGINS=http://localhost:4001

# ===========================
# FRONTEND
# ===========================
NEXT_PUBLIC_API_URL=http://localhost:4000/api

# ===========================
# MONITORING (optionnel)
# ===========================
# SENTRY_DSN=
# GRAFANA_URL=
# PROMETHEUS_URL=

# ===========================
# LOGS
# ===========================
LOG_LEVEL=debug
