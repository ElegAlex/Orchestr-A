# ===========================
# DATABASE
# ===========================
DATABASE_URL="postgresql://orchestr_a:orchestr_a_dev_password@localhost:5432/orchestr_a_v2"
POSTGRES_USER=orchestr_a
POSTGRES_PASSWORD=orchestr_a_dev_password
POSTGRES_DB=orchestr_a_v2
POSTGRES_PORT=5432

# ===========================
# REDIS
# ===========================
REDIS_URL="redis://localhost:6379"
REDIS_PORT=6379

# ===========================
# JWT & AUTH
# ===========================
# Generate with: openssl rand -hex 32
JWT_SECRET=
# Access token TTL (short — rotated via refresh token)
JWT_ACCESS_TTL=15m
# Refresh token TTL
JWT_REFRESH_TTL=7d
# Legacy alias for JWT_ACCESS_TTL — read as fallback if JWT_ACCESS_TTL unset
JWT_EXPIRES_IN=15m
# OBS-028 — keys the HMAC that pseudonymises attempted-login identifiers
# (LOGIN_FAILURE / ACCOUNT_LOCKED) in the immutable audit trail. REQUIRED in
# every environment: the API refuses to boot without it (no raw-identifier
# fallback). Generate with: openssl rand -hex 32. Keep it STABLE / long-lived —
# rotating it breaks hash-correlation of historical attempts.
AUDIT_HASH_KEY=
# Whether POST /auth/reset-password-token returns the raw token + resetUrl in
# its response body. NEVER set to `true` in production — the API will refuse
# to start (boot-time guard). Set to `true` for dev/E2E only so the admin UI
# can display the reset link until SMTP is wired.
AUTH_EXPOSE_RESET_TOKEN=false
# SEC-008: self-registration gate — default false (closed). Set to true only
# in environments where external users should be able to create accounts.
# Even when true, accounts require admin activation before first login.
REGISTRATION_ENABLED=false
# SEC-008: comma-separated email domain allowlist for self-registration.
# Leave empty (or unset) to allow any domain when REGISTRATION_ENABLED=true.
# Example: REGISTRATION_EMAIL_DOMAIN=mairie.fr,collectivite.fr
REGISTRATION_EMAIL_DOMAIN=

# ===========================
# SEED
# ===========================
SEED_ADMIN_PASSWORD=  # set to seed an admin user; leave empty to auto-generate (non-prod) or skip (prod)

# ===========================
# API
# ===========================
API_PORT=4000
API_PREFIX=/api
# Server-side only — used by API proxy route handler
API_URL=http://localhost:4000
NODE_ENV=development
SWAGGER_ENABLED=false  # NEVER set to true in production without SWAGGER_USER/SWAGGER_PASS
SWAGGER_USER=          # if set with SWAGGER_PASS, protects /api/docs with basic auth
SWAGGER_PASS=
# SEC-012: CORS_ORIGIN is the canonical variable (comma-separated list of allowed origins).
# ALLOWED_ORIGINS is a deprecated alias kept for backward compatibility.
CORS_ORIGIN=http://localhost:4001
# ALLOWED_ORIGINS=http://localhost:4001  # deprecated alias — use CORS_ORIGIN instead

# RBAC zero-trust guard mode (PermissionsGuardV2).
# - 'enforce' (default): routes without @Public/@AllowSelfService/
#   @RequirePermissions/@RequireAnyPermission are refused.
# - 'permissive': routes without RBAC decorators are allowed but logged.
#   Only for migration; FORBIDDEN in production (boot-assert in main.ts).
RBAC_GUARD_MODE=enforce

# ===========================
# FRONTEND
# ===========================
NEXT_PUBLIC_API_URL=http://localhost:4000/api

# ===========================
# MONITORING (optionnel)
# ===========================
# SENTRY_DSN=
# GRAFANA_URL=
# PROMETHEUS_URL=
# SA-SEC-012: Token that protects GET /api/metrics (Prometheus scraping).
# If unset, the endpoint is open (acceptable in dev/test; REQUIRED in production).
# Generate with: openssl rand -hex 32
METRICS_TOKEN=

# ===========================
# LOGS
# ===========================
LOG_LEVEL=debug
